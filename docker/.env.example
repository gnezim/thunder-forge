# ============================================================================
# Core Cluster Configuration
# ============================================================================

# API key for LiteLLM proxy authentication
LITELLM_MASTER_KEY=sk-local-cluster-key

# PostgreSQL configuration for LiteLLM database
POSTGRES_PASSWORD=litellm-local
PG_PORT=5434

# LiteLLM proxy settings
LITELLM_WORKERS=4
LITELLM_URL=http://localhost:4000/ui

# Optional FINN (future feature) integration key
# FINN_LITELLM_KEY=

# ============================================================================
# Open WebUI Configuration
# ============================================================================

# WebUI credentials
UI_USERNAME=admin
UI_PASSWORD=changeme

# WebUI security and access
WEBUI_SECRET_KEY=change-this-secret
WEBUI_AUTH=true
ENABLE_SIGNUP=true
WEBUI_PORT=8080

# OpenAI API configuration for WebUI
OPENAI_API_BASE_URLS=http://litellm:4000/v1

# Direct WebUI URL
OPENWEBUI_URL=http://localhost:8080

# ============================================================================
# Admin UI - Database
# ============================================================================

# Thunder Admin database user password
ADMIN_DB_PASSWORD=admin-local

# ============================================================================
# Admin UI - Gateway SSH Access (REQUIRED)
# ============================================================================

# SSH host, port, and user for accessing the gateway node
GATEWAY_SSH_HOST=localhost
GATEWAY_SSH_PORT=22
GATEWAY_SSH_USER=admin
# Host path to SSH private key — mounted read-only into the admin-ui container
GATEWAY_SSH_KEY=~/.ssh/id_ed25519

# Fallback SSH user for inference nodes (optional, used if node.user not set in config)
TF_SSH_USER=admin

# ============================================================================
# Admin UI - Thunder Forge Integration (REQUIRED)
# ============================================================================

# Absolute path to the Thunder Forge repository (required for deployment commands)
THUNDER_FORGE_DIR=/path/to/thunder-forge

# ============================================================================
# Admin UI - Model & Optional Features
# ============================================================================

# HuggingFace API token for private model access
HF_TOKEN=

# Session timeout in hours
SESSION_TIMEOUT_HOURS=24

# Display timezone for the admin UI
DISPLAY_TZ=UTC

# Grafana dashboard URL (optional, for monitoring)
# GRAFANA_URL=
