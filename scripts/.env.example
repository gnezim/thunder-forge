# Thunder Forge — Node Bootstrap Configuration
# Copy to .env and adjust values:
#   cp .env.example .env

# thunder-forge clone location
TF_DIR=~/thunder-forge

# Node log directory
TF_LOG_DIR=~/logs

# SSH key path (for gateway → node access)
TF_SSH_KEY=~/.ssh/id_ed25519

# Git clone URL
TF_REPO_URL=https://github.com/shared-goals/thunder-forge.git

# HuggingFace cache directory
HF_HOME=~/.cache/huggingface

# Proxy settings (leave empty if not needed)
# HTTP_PROXY=socks5h://127.0.0.1:1080
# HTTPS_PROXY=socks5h://127.0.0.1:1080
