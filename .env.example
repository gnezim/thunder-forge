# Thunder Forge — project configuration
# Copy to .env and adjust values. Environment variables take precedence.
# Used by both `thunder-forge` CLI commands and `scripts/setup-node.sh`.

# Default SSH user for inference nodes (overridden by per-node 'user' in node-assignments.yaml)
TF_SSH_USER=admin

# SSH key path
TF_SSH_KEY=~/.ssh/id_ed25519

# HuggingFace cache directory (must have enough space for model weights)
HF_HOME=~/.cache/huggingface

# Disable macOS sleep on inference nodes (set false to skip)
TF_DISABLE_SLEEP=true

# Log directory on inference nodes
# TF_LOG_DIR=~/logs

# Git clone URL (for setup-node.sh infra)
# TF_REPO_URL=https://github.com/shared-goals/thunder-forge.git

# Proxy settings (uncomment if outbound internet is filtered)
# HTTP_PROXY=socks5h://127.0.0.1:1080
# HTTPS_PROXY=socks5h://127.0.0.1:1080
