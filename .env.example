# Thunder Forge — unified configuration
# Copy to .env and fill in required fields.
# Used by the thunder-forge CLI, setup-node.sh, and Docker Compose (via -f docker/docker-compose.yml).

# ============================================================================
# Core secrets — all required. Generate each with: openssl rand -hex 32
# ============================================================================

LITELLM_MASTER_KEY=sk-local-cluster-key
POSTGRES_PASSWORD=litellm-local
WEBUI_SECRET_KEY=change-this-secret
ADMIN_DB_PASSWORD=admin-local

# ============================================================================
# SSH access — required
# ============================================================================

# SSH user on the gateway node (used by admin-ui container and CLI node connections)
GATEWAY_SSH_USER=admin

# Host path to SSH private key (mounted read-only into the admin-ui container)
GATEWAY_SSH_KEY=~/.ssh/id_ed25519

# ============================================================================
# Thunder Forge integration — required
# ============================================================================

# Absolute path to the thunder-forge repo on the gateway
THUNDER_FORGE_DIR=~/thunder-forge

# ============================================================================
# Admin UI — optional
# ============================================================================

# HuggingFace token — required for gated/fast model downloads
# HF_TOKEN=

# Admin UI session timeout in hours
SESSION_TIMEOUT_HOURS=24

# Timezone for timestamps in the Admin UI (e.g. Europe/Moscow, America/New_York)
DISPLAY_TZ=UTC

# Grafana dashboard URL (shown as a link in the Admin UI)
# GRAFANA_URL=

# ============================================================================
# Open WebUI
# ============================================================================

UI_USERNAME=admin
UI_PASSWORD=changeme
WEBUI_AUTH=true
ENABLE_SIGNUP=true
WEBUI_PORT=8080
OPENAI_API_BASE_URLS=http://litellm:4000/v1
OPENWEBUI_URL=http://localhost:8080

# ============================================================================
# LiteLLM & infrastructure
# ============================================================================

LITELLM_WORKERS=4
# Non-standard port to avoid conflicts with a local Postgres instance
PG_PORT=5434
LITELLM_URL=http://localhost:4000/ui

# ============================================================================
# CLI-only settings (not used by Docker)
# ============================================================================

# Local path to the thunder-forge repo (used by setup-node.sh)
TF_DIR=~/thunder-forge

# HuggingFace cache directory on inference nodes
HF_HOME=~/.cache/huggingface

# Disable macOS sleep on inference nodes
TF_DISABLE_SLEEP=true

# Log directory on inference nodes
# TF_LOG_DIR=~/logs

# Git clone URL (for setup-node.sh)
# TF_REPO_URL=https://github.com/shared-goals/thunder-forge.git

# ============================================================================
# Proxy (uncomment if outbound internet is filtered)
# ============================================================================

# HTTP_PROXY=socks5h://127.0.0.1:1080
# HTTPS_PROXY=socks5h://127.0.0.1:1080
